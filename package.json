{
  "name": "mobile-automation",
  "version": "1.0.0",
  "description": "Native mobile automation framework built with WebdriverIO, Appium and TypeScript using the Page Object Model.",
  "main": "wdio.conf.ts",
  "scripts": {
    "test": "wdio run wdio.conf.ts",
    "test:smoke": "wdio run wdio.conf.ts --spec test/specs/smoke.spec.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "webdriverio",
    "appium",
    "mobile-automation",
    "typescript",
    "page-object-model",
    "android",
    "ios",
    "qa"
  ],
  "author": "Lucia Esporta",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/types": "^9.27.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-wdio": "^9.27.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "webdriverio": "^9.27.0"
  }
}
